{
  "gateway": {
    "bind": "0.0.0.0",
    "port": 8090,
    "auth": {
      "mode": "token",
      "token": "${PHYSICLAW_GATEWAY_TOKEN}"
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "vllm/GLM-4.7-Flash_AWQ-W4A16_GS32",
        "fallbacks": []
      }
    }
  },
  "models": {
    "providers": {
      "vllm": {
        "baseUrl": "http://host.docker.internal:8001/v1",
        "apiKey": "${VLLM_API_KEY}",
        "api": "openai-responses",
        "models": [
          {
            "id": "GLM-4.7-Flash_AWQ-W4A16_GS32",
            "name": "GLM-4.7 Flash AWQ",
            "api": "openai-responses",
            "reasoning": true,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 88064,
            "maxTokens": 8192,
            "compat": { "thinkingFormat": "qwen" }
          }
        ]
      }
    }
  },
  "tools": {
    "profile": "messaging",
    "deny": ["group:automation", "group:runtime", "group:fs", "sessions_spawn", "sessions_send"],
    "exec": {
      "security": "allowlist",
      "ask": "always"
    }
  },
  "logging": {
    "redactSensitive": "tools"
  },
  "plugins": {
    "slots": { "memory": "memory-hybrid" },
    "entries": {
      "memory-hybrid": {
        "enabled": true,
        "config": {
          "embedding": {
            "provider": "local",
            "model": "hf:ggml-org/embeddinggemma-300m-qat-q8_0-GGUF/embeddinggemma-300m-qat-Q8_0.gguf"
          },
          "sqlitePath": "/home/node/.physiclaw/workspace/memory/facts.db",
          "lanceDbPath": "/home/node/.physiclaw/workspace/memory/lancedb",
          "autoCapture": true,
          "autoRecall": true
        }
      }
    }
  }
}
